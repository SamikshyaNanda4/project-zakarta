{
  "name": "tbr",
  "private": true,
  "scripts": {
    "dev:zakarta": "pnpm --filter zakarta dev",
    "dev:api": "pnpm --filter api dev",
    "build:zakarta": "pnpm --filter zakarta build",
    "build:api": "pnpm --filter api build",
    "start": "pnpm run --parallel start",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "start-dev-db": "docker compose -f docker/docker-compose-dev.yaml up -d"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
